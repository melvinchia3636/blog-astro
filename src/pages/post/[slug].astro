---
import Layout from '../../layouts/Layout.astro';
import PostViewer from '../../components/PostViewer';
import { getCollection, render } from 'astro:content';

// folder-based posts have id like "slug/index" — normalise to bare slug

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\/index$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const lineCount = post.body ? post.body.split('\n').length : 0;
const charCount = post.body ? post.body.length : 0;
const slug = post.id.replace(/\/index$/, '');

const wordCount = post.body ? post.body.trim().split(/\s+/).length : 0;
const readTime = `${Math.max(1, Math.round(wordCount / 200))} min read`;
---

<Layout title={`${post.data.title} — Melvin's Life Journal`}>
  <PostViewer
    client:load
    slug={slug}
    title={post.data.title}
    excerpt={post.data.excerpt}
    date={post.data.date}
    lineCount={lineCount}
    charCount={charCount}
    readTime={readTime}
  >
    <Content />
  </PostViewer>
</Layout>
