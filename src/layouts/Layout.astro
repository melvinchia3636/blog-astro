---
import StatusLine from '../components/StatusLine';
import ThemeToggle from '../components/ThemeToggle';
import '../styles/tailwind.css';
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = "Melvin's Life Journal" } = Astro.props;

const currentTime = new Date().toLocaleTimeString("en-US", {
  hour12: false,
  hour: "2-digit",
  minute: "2-digit",
});
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <script is:inline>
      (function () {
        var stored = localStorage.getItem('theme');
        var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (stored === 'light' || (!stored && !prefersDark)) {
          document.documentElement.classList.add('light');
        }
      })();
    </script>
  </head>
  <body>
    <div class="h-full bg-bg-primary overflow-hidden">
      <!-- Terminal Window -->
      <div class="h-full flex flex-col bg-bg-secondary border border-border rounded-lg overflow-hidden">
        <!-- Terminal Title Bar - Fixed -->
        <div class="bg-bg-tertiary px-4 py-2 flex items-center justify-between shrink-0 sticky top-0 z-10">
          <div class="flex items-center gap-2">
            <span class="w-3 h-3 rounded-full bg-segment-red"></span>
            <span class="w-3 h-3 rounded-full bg-segment-yellow"></span>
            <span class="w-3 h-3 rounded-full bg-segment-green"></span>
          </div>
          <span class="text-text-muted text-xs">
            melvin@blog: ~/journal
          </span>
          <ThemeToggle client:load />
        </div>

        <!-- Terminal Body - Scrollable -->
        <div class="flex-1 flex flex-col overflow-y-auto overflow-x-hidden">
          <header class="px-6 pt-4">
            <StatusLine client:load directory="~/blog" />
            <div class="flex items-center">
              <span class="text-segment-magenta font-bold">❯</span>
              <span class="ml-2 text-text-primary">cat journal.md</span>
            </div>
            <div class="mt-2 text-text-muted text-sm">
              # Melvin's Life Journal — Just some random thoughts
            </div>
          </header>

          <slot />
        </div>
      </div>
    </div>

    <script>
      import { animate } from "animejs";

      function staggerFadeIn(selector: string, delay = 0) {
        const elements = document.querySelectorAll(selector);
        if (elements.length === 0) return;
        animate(selector, {
          translateY: [20, 0],
          opacity: [0, 1],
          duration: 600,
          delay: (_: any, i: number) => delay + i * 80,
          easing: "outExpo",
        });
      }

      function fadeIn(selector: string, delay = 0) {
        const elements = document.querySelectorAll(selector);
        if (elements.length === 0) return;
        animate(selector, {
          translateY: [30, 0],
          opacity: [0, 1],
          duration: 800,
          delay,
          easing: "outExpo",
        });
      }

      function slideInLeft(selector: string, delay = 0) {
        const elements = document.querySelectorAll(selector);
        if (elements.length === 0) return;
        animate(selector, {
          translateX: [-50, 0],
          opacity: [0, 1],
          duration: 600,
          delay,
          easing: "outExpo",
        });
      }

      function slideInRight(selector: string, delay = 0) {
        const elements = document.querySelectorAll(selector);
        if (elements.length === 0) return;
        animate(selector, {
          translateX: [50, 0],
          opacity: [0, 1],
          duration: 600,
          delay,
          easing: "outExpo",
        });
      }

      // Make available globally for page scripts
      (window as any).__animations = { staggerFadeIn, fadeIn, slideInLeft, slideInRight };
    </script>
  </body>
</html>
